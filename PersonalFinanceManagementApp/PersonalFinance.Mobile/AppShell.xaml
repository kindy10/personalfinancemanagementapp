<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PersonalFinance.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:PersonalFinance.Mobile.Views">

    <ShellContent Route="login"
                  ContentTemplate="{DataTemplate views:LoginPage}" />
    <ShellContent Route="register"
                  ContentTemplate="{DataTemplate views:RegisterPage}"/>

    <ShellContent Route="dashboard"
                  ContentTemplate="{DataTemplate views:DashboardPage}" />
    <ShellContent Route="transactions"
                  ContentTemplate="{DataTemplate views:TransactionsPage}"/>
    <ShellContent
                   Route="transaction-form"
                   ContentTemplate="{DataTemplate views:TransactionFormPage}" />

    <ShellContent
                   Route="categories"
                   ContentTemplate="{DataTemplate views:CategoriesPage}"/>
    <ShellContent
                    Route="category-form"
                    ContentTemplate="{DataTemplate views:CategoryFormPage}"/>

</Shell>
