<?xml version="1.0" encoding="utf-8" ?>

<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="PersonalFinance.Mobile.Controls.BottomNav">

    <Frame
        Margin="20"
        Padding="15,12"
        CornerRadius="35"
        BackgroundColor="#1E293B"
        BorderColor="Transparent"
        HasShadow="True">

        <Grid
            ColumnDefinitions="*,*,*,*,*">

            <!-- DASHBOARD -->

            <Button
                Grid.Column="0"
                Text="🏠"
                FontSize="24"
                BackgroundColor="Transparent"
                TextColor="White"
                Clicked="OnDashboardClicked" />



            <!-- TRANSACTIONS -->

            <Button
                Grid.Column="1"
                Text="📊"
                FontSize="24"
                BackgroundColor="Transparent"
                TextColor="White"
                Clicked="OnTransactionsClicked" />



            <!-- ADD -->

            <Frame
                Grid.Column="2"
                WidthRequest="60"
                HeightRequest="60"
                CornerRadius="30"
                Padding="0"
                BackgroundColor="#3B82F6"
                BorderColor="Transparent"
                HorizontalOptions="Center">

                <Button
                    Text="+"
                    FontSize="32"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    Clicked="OnAddClicked" />

            </Frame>



            <!-- BUDGET -->

            <Button
                Grid.Column="3"
                Text="💰"
                FontSize="24"
                BackgroundColor="Transparent"
                TextColor="White"
                Clicked="OnBudgetsClicked" />



            <!-- PROFILE -->

            <Button
                Grid.Column="4"
                Text="👤"
                FontSize="24"
                BackgroundColor="Transparent"
                TextColor="White"
                Clicked="OnProfileClicked" />

        </Grid>

    </Frame>

</ContentView>