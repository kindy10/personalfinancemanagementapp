<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
     xmlns:layouts="clr-namespace:PersonalFinance.Mobile.Layouts"
    x:Class="PersonalFinance.Mobile.Views.TransactionsPage"
    Title="Transactions">
    <layouts:MainLayoutPage>
        <layouts:MainLayoutPage.PageContent>


            <ScrollView>

                <VerticalStackLayout
                    Padding="20"
                    Spacing="15">

                    <!-- PAGE TITLE -->

                    <Label
                        Text="Transactions"
                        Style="{StaticResource TitleLabel}" />



                    <!-- ADD TRANSACTION BUTTON -->

                    <Button
                        Text="+ Add Transaction"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding AddCommand}" />



                    <!-- TRANSACTIONS LIST -->

                    <CollectionView
                        ItemsSource="{Binding Transactions}">

                        <CollectionView.ItemTemplate>

                            <DataTemplate>

                                <!-- TRANSACTION CARD -->

                                <Frame
                                    Style="{StaticResource CardFrame}">

                                    <VerticalStackLayout
                                        Spacing="14">

                                        <!-- TOP SECTION -->

                                        <Grid
                                            ColumnDefinitions="*,Auto">

                                            <!-- LEFT SIDE -->

                                            <VerticalStackLayout
                                                Spacing="4">

                                                <!-- CATEGORY -->

                                                <Label
                                                    Text="{Binding Category.Name}"
                                                    FontSize="20"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource TextColor}" />



                                                <!-- DESCRIPTION -->

                                                <Label
                                                    Text="{Binding Description}"
                                                    Style="{StaticResource NormalLabel}" />

                                            </VerticalStackLayout>



                                            <!-- RIGHT SIDE -->

                                            <VerticalStackLayout
                                                Grid.Column="1"
                                                HorizontalOptions="End"
                                                Spacing="4">

                                                <!-- AMOUNT -->

                                                <Label
                                                    Text="{Binding Amount,
                                                           StringFormat='-{0:C}'}"
                                                    FontSize="24"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource DangerColor}"
                                                    HorizontalTextAlignment="End" />



                                                <!-- DATE -->

                                                <Label
                                                    Text="{Binding Date,
                                                           StringFormat='{0:dd MMM yyyy}'}"
                                                    FontSize="13"
                                                    TextColor="{StaticResource SecondaryTextColor}"
                                                    HorizontalTextAlignment="End" />

                                            </VerticalStackLayout>

                                        </Grid>



                                        <!-- ACTION BUTTONS -->

                                        <Grid
                                            ColumnDefinitions="*,*"
                                            ColumnSpacing="10">

                                            <!-- EDIT BUTTON -->

                                            <Button
                                                Grid.Column="0"
                                                Text="Edit"
                                                Style="{StaticResource PrimaryButton}"
                                                HeightRequest="45"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                                  Path=BindingContext.EditCommand}"
                                                CommandParameter="{Binding .}" />



                                            <!-- DELETE BUTTON -->

                                            <Button
                                                Grid.Column="1"
                                                Text="Delete"
                                                Style="{StaticResource DangerButton}"
                                                HeightRequest="45"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                                  Path=BindingContext.DeleteCommand}"
                                                CommandParameter="{Binding .}" />

                                        </Grid>

                                    </VerticalStackLayout>

                                </Frame>

                            </DataTemplate>

                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </VerticalStackLayout>

            </ScrollView>
        </layouts:MainLayoutPage.PageContent>
    </layouts:MainLayoutPage>

</ContentPage>