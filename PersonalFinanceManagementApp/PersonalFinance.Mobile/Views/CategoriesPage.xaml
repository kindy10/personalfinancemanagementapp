<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:layouts="clr-namespace:PersonalFinance.Mobile.Layouts"
    x:Class="PersonalFinance.Mobile.Views.CategoriesPage"
    Title="Categories">

    <layouts:MainLayoutPage>
        <layouts:MainLayoutPage.PageContent>

            <VerticalStackLayout
                Padding="20"
                Spacing="20">

               

                <Grid
                        ColumnDefinitions="*,Auto"
                        Margin="0,0,0,10">

                    <VerticalStackLayout>
                        <!-- PAGE TITLE -->

                        <Label
                            Text="Categories"
                            Style="{StaticResource TitleLabel}" />

                        <Label
                                Text="Manage your income and expense categories"
                                Style="{StaticResource NormalLabel}" />

                    </VerticalStackLayout>
                    
            <!---Add Button-->
                    <Button
                            Grid.Column="1"
                            Text="+"
                            WidthRequest="55"
                            HeightRequest="55"
                            CornerRadius="28"
                            Command="{Binding AddCommand}"
                            Style="{StaticResource PrimaryButton}" />

                </Grid>



                <!-- CATEGORIES LIST -->

                <CollectionView
                    ItemsSource="{Binding Categories}">

                    <CollectionView.ItemTemplate>

                        <DataTemplate>

                            <!-- CATEGORY CARD -->

                            <Frame
    Style="{StaticResource CardFrame}"
    Padding="15"
    Margin="0,0,0,12">

                                <Grid
        ColumnDefinitions="60,*,Auto">

                                    <!-- Icon -->

                                    <Frame
            WidthRequest="50"
            HeightRequest="50"
            CornerRadius="25"
            Padding="12"
            BackgroundColor="{StaticResource PrimaryColor}"
            BorderColor="Transparent">

                                        <Image
                Source="{Binding IconSource}" />

                                    </Frame>

                                    <!-- Info -->

                                    <VerticalStackLayout
            Grid.Column="1"
            Margin="15,0">

                                        <Label
                Text="{Binding Name}"
                FontSize="18"
                FontAttributes="Bold"
                TextColor="{StaticResource TextColor}" />

                                        <Label
                Text="{Binding Type}"
                Style="{StaticResource NormalLabel}" />

                                    </VerticalStackLayout>

                                    <!-- Menu -->

                                    <Button
                                        Grid.Column="2"
                                        Text="⋮"
                                        BackgroundColor="Transparent"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                          Path=BindingContext.ShowOptionsCommand}"
                                        CommandParameter="{Binding .}" />

                                </Grid>

                            </Frame>

                        </DataTemplate>

                    </CollectionView.ItemTemplate>

                </CollectionView>

            </VerticalStackLayout>
        </layouts:MainLayoutPage.PageContent>
    </layouts:MainLayoutPage>

</ContentPage>