<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="PersonalFinance.Mobile.Views.CategoryFormPage"
    Title="Category">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="20">

            <!-- PAGE TITLE -->
            <Label
                Text="{Binding PageTitle}"
                Style="{StaticResource TitleLabel}" />

            <!-- FORM CARD -->
            <Frame
                Style="{StaticResource CardFrame}">

                <VerticalStackLayout
                    Spacing="18">

                    <!-- CATEGORY NAME -->
                    <Entry
                        Placeholder="Category Name"
                        Text="{Binding Name}"
                        Style="{StaticResource AppEntry}" />

                    <!-- CATEGORY TYPE -->
                    <VerticalStackLayout
                         Spacing="10">

                        <Label
                            Text="Category Type"
                            Style="{StaticResource NormalLabel}" />

                        <HorizontalStackLayout Spacing="30">

                            <RadioButton
                                Content="Income"
                                GroupName="CategoryType"
                                IsChecked="{Binding IsIncome}" />

                            <RadioButton
                                Content="Expense"
                                GroupName="CategoryType"
                                IsChecked="{Binding IsExpense}" />

                        </HorizontalStackLayout>

                    </VerticalStackLayout>

                    <!-- SAVE BUTTON -->
                    <Button
                        Text="Save Category"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}" />

                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>