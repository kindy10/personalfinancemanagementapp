<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui" 
    x:Class="PersonalFinance.Mobile.Views.DashboardPage"
    BackgroundColor="#111827">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="20">

            <!-- HEADER -->

            <Label
                Text="Dashboard"
                FontSize="34"
                FontAttributes="Bold"
                TextColor="White" />



            <!-- INCOME CARD -->

            <Frame
                CornerRadius="25"
                Padding="20"
                BackgroundColor="White"
                HasShadow="True">

                <VerticalStackLayout
                    Spacing="8">

                    <Label
                        Text="Total Income"
                        FontSize="18"
                        TextColor="#6B7280" />

                    <Label
                        Text="{Binding TotalIncome,
                               StringFormat='{0:C}'}"
                        FontSize="32"
                        FontAttributes="Bold"
                        TextColor="#16A34A" />

                </VerticalStackLayout>

            </Frame>



            <!-- EXPENSE CARD -->

            <Frame
                CornerRadius="25"
                Padding="20"
                BackgroundColor="White"
                HasShadow="True">

                <VerticalStackLayout
                    Spacing="8">

                    <Label
                        Text="Total Expense"
                        FontSize="18"
                        TextColor="#6B7280" />

                    <Label
                        Text="{Binding TotalExpense,
                               StringFormat='{0:C}'}"
                        FontSize="32"
                        FontAttributes="Bold"
                        TextColor="#DC2626" />

                </VerticalStackLayout>

            </Frame>



            <!-- BALANCE CARD -->

            <Frame
                CornerRadius="25"
                Padding="20"
                BackgroundColor="White"
                HasShadow="True">

                <VerticalStackLayout
                    Spacing="8">

                    <Label
                        Text="Balance"
                        FontSize="18"
                        TextColor="#6B7280" />

                    <Label
                        Text="{Binding Balance,
                               StringFormat='{0:C}'}"
                        FontSize="32"
                        FontAttributes="Bold"
                        TextColor="#2563EB" />

                </VerticalStackLayout>

            </Frame>
            <!-- EXPENSE CHART -->

            <Label
                  Text="Expense Analytics"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="White"
                   Margin="0,20,0,10" />

            <Frame
                     BackgroundColor="White"
                     CornerRadius="25"
                      Padding="20"
                      HasShadow="True">

                <VerticalStackLayout>

                    <lvc:PieChart
                              Series="{Binding ExpenseSeries}"
                              HeightRequest="300" />

                </VerticalStackLayout>

            </Frame>


            <!-- MONTHLY TRENDS -->

            <Label
                Text="Monthly Trends"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="White"
                Margin="0,20,0,10" />

            <Frame
                BackgroundColor="White"
                CornerRadius="25"
                Padding="20"
                HasShadow="True">

                <VerticalStackLayout>

                    <lvc:CartesianChart
                        Series="{Binding TrendSeries}"
                        XAxes="{Binding XAxes}"
                        HeightRequest="300" />

                </VerticalStackLayout>

            </Frame>


            <!-- QUICK ACTIONS -->

            <Label
                Text="Quick Actions"
                FontSize="24"
                FontAttributes="Bold"
                TextColor="White"
                Margin="0,10,0,5" />

            <Grid
                ColumnDefinitions="*,*"
                RowDefinitions="Auto,Auto"
                ColumnSpacing="10"
                RowSpacing="10">

                <!-- TRANSACTIONS -->

                <Button
                    Grid.Row="0"
                    Grid.Column="0"
                    Text="Transactions"
                    Command="{Binding GoToTransactionsCommand}"
                    CornerRadius="20"
                    HeightRequest="60"
                    FontAttributes="Bold"
                    BackgroundColor="#2563EB"
                    TextColor="White" />



                <!-- CATEGORIES -->

                <Button
                    Grid.Row="0"
                    Grid.Column="1"
                    Text="Categories"
                    Command="{Binding GoToCategoriesCommand}"
                    CornerRadius="20"
                    HeightRequest="60"
                    FontAttributes="Bold"
                    BackgroundColor="#7C3AED"
                    TextColor="White" />



                <!-- BUDGETS -->

                <Button
                    Grid.Row="1"
                    Grid.Column="0"
                    Text="Budgets"
                    Command="{Binding GoToBudgetCommand}"
                    CornerRadius="20"
                    HeightRequest="60"
                    FontAttributes="Bold"
                    BackgroundColor="#059669"
                    TextColor="White" />



                <!-- PROFILE -->

                <Button
                    Grid.Row="1"
                    Grid.Column="1"
                    Text="Profile"
                    Command="{Binding GoToProfileCommand}"
                    CornerRadius="20"
                    HeightRequest="60"
                    FontAttributes="Bold"
                    BackgroundColor="#EA580C"
                    TextColor="White" />

            </Grid>



            <!-- BUDGET USAGE -->

            <Label
                Text="Budget Usage"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="White"
                Margin="0,20,0,10" />



            <CollectionView
                HeightRequest="350"
                ItemsSource="{Binding BudgetUsages}">

                <CollectionView.ItemTemplate>

                    <DataTemplate>

                        <Frame
                            CornerRadius="25"
                            Padding="20"
                            Margin="0,8"
                            HasShadow="True"
                            BackgroundColor="White">

                            <VerticalStackLayout
                                Spacing="12">

                                <!-- CATEGORY NAME -->

                                <Label
                                    Text="{Binding CategoryName}"
                                    FontSize="22"
                                    FontAttributes="Bold"
                                    TextColor="#111827" />



                                <!-- SPENT / LIMIT -->

                                <Grid
                                    ColumnDefinitions="*,Auto">

                                    <Label
                                        Text="{Binding Spent,
                                               StringFormat='Spent: {0:C}'}"
                                        FontSize="16"
                                        TextColor="#6B7280" />

                                    <Label
                                        Grid.Column="1"
                                        Text="{Binding Limit,
                                               StringFormat='Limit: {0:C}'}"
                                        FontSize="16"
                                        TextColor="#6B7280" />

                                </Grid>



                                <!-- PROGRESS BAR -->

                                <ProgressBar
                                    Progress="{Binding PercentageUsed}"
                                    HeightRequest="10"
                                    BackgroundColor="#E5E7EB"
                                    ProgressColor="#2563EB" />



                                <!-- REMAINING -->

                                <Grid
                                    ColumnDefinitions="*,Auto">

                                    <Label
                                        Text="{Binding Remaining,
                                               StringFormat='Remaining: {0:C}'}"
                                        FontSize="15"
                                        TextColor="#16A34A" />

                                    <Label
                                        Grid.Column="1"
                                        Text="{Binding PercentageUsed,
                                               StringFormat='{0:P0}'}"
                                        FontSize="15"
                                        FontAttributes="Bold"
                                        TextColor="#DC2626" />

                                </Grid>
                            </VerticalStackLayout>

                        </Frame>

                    </DataTemplate>

                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>