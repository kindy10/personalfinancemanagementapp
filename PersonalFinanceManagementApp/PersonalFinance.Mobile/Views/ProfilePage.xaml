<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="PersonalFinance.Mobile.Views.ProfilePage"
    Title="Profile">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="20">

            <!-- Title -->
            <Label
                Text="My Profile"
                Style="{StaticResource PageTitleStyle}" />

            <!-- Name -->
            <Entry
                Placeholder="Name"
                Text="{Binding Name}" />

            <!-- Surname -->
            <Entry
                Placeholder="Surname"
                Text="{Binding SurName}" />

            <!-- Email -->
            <Entry
                Placeholder="Email"
                Keyboard="Email"
                Text="{Binding Email}" />

            <!-- Save -->
            <Button
                Text="Save Changes"
                Command="{Binding SaveCommand}" />

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>