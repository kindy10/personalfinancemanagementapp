<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:layouts="clr-namespace:PersonalFinance.Mobile.Layouts"
    x:Class="PersonalFinance.Mobile.Views.ProfilePage"
    Title="Profile">
    <layouts:MainLayoutPage>
        <layouts:MainLayoutPage.PageContent>


            <ScrollView>

            <VerticalStackLayout
                    Padding="20"
                    Spacing="20">

                <!-- PAGE TITLE -->

                <Label
                        Text="My Profile"
                        Style="{StaticResource TitleLabel}" />
                <Frame
                        WidthRequest="120"
                        HeightRequest="120"
                        CornerRadius="60"
                        BackgroundColor="{StaticResource PrimaryColor}"
                        HorizontalOptions="Center"
                        BorderColor="Transparent">

                        <Label
                            Text="👤"
                            FontSize="50"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>
                        

                    </Frame>
                <VerticalStackLayout
                        HorizontalOptions="Center"
                        Spacing="2">

                        <Label
                            Text="{Binding Name}"
                            FontSize="28"
                            FontAttributes="Bold"
                            TextColor="{StaticResource TextColor}" />

                        <Label
                                Text="{Binding Email}"
                                Style="{StaticResource SubtitleLabel}" />

                </VerticalStackLayout>
                    <Frame
    Style="{StaticResource CardFrame}"
    Padding="15">

                        <Grid ColumnDefinitions="*,*,*">

                            <!-- Transactions -->

                            <VerticalStackLayout
            HorizontalOptions="Center">

                                <Label
                                    Text="{Binding TransactionsCount}"
                                    FontSize="24"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource PrimaryColor}" />

                                <Label
                Text="Transactions"
                Style="{StaticResource SubtitleLabel}" />

                            </VerticalStackLayout>

                            <!-- Budgets -->

                            <VerticalStackLayout
            Grid.Column="1"
            HorizontalOptions="Center">

                                <Label
                                Text="{Binding BudgetsCount}"
                                FontSize="24"
                                FontAttributes="Bold"
                                TextColor="{StaticResource SuccessColor}" />

                                <Label
                                    Text="Budgets"
                                    Style="{StaticResource SubtitleLabel}" />

                            </VerticalStackLayout>

                            <!-- Categories -->

                            <VerticalStackLayout
                                Grid.Column="2"
                                HorizontalOptions="Center">

                                <Label
                                    Text="{Binding CategoriesCount}"
                                    FontSize="24"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource WarningColor}" />

                                <Label
                                    Text="Categories"
                                    Style="{StaticResource SubtitleLabel}" />

                            </VerticalStackLayout>

                        </Grid>

                    </Frame>



                    <!-- PROFILE CARD -->

                <Frame
                        Style="{StaticResource CardFrame}">

                    <VerticalStackLayout
                            Spacing="18">

                        <!-- NAME -->

                        <VerticalStackLayout
                                Spacing="6">

                            <Label
                                    Text="Name"
                                    Style="{StaticResource NormalLabel}" />

                            <Entry
                                    Placeholder="Enter your name"
                                    Text="{Binding Name}"
                                    Style="{StaticResource AppEntry}" />

                        </VerticalStackLayout>



                        <!-- SURNAME -->

                        <VerticalStackLayout
                                Spacing="6">

                            <Label
                                    Text="Surname"
                                    Style="{StaticResource NormalLabel}" />

                            <Entry
                                    Placeholder="Enter your surname"
                                    Text="{Binding SurName}"
                                    Style="{StaticResource AppEntry}" />

                        </VerticalStackLayout>



                        <!-- EMAIL -->

                        <VerticalStackLayout
                                Spacing="6">

                            <Label
                                    Text="Email"
                                    Style="{StaticResource NormalLabel}" />

                            <Entry
                                    Placeholder="Enter your email"
                                    Keyboard="Email"
                                    Text="{Binding Email}"
                                    Style="{StaticResource AppEntry}" />

                        </VerticalStackLayout>



                        <!-- SAVE BUTTON -->

                        <Button
                                Text="Save Changes"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,10,0,0" />

                    </VerticalStackLayout>

                </Frame>
                    <Frame
                            Style="{StaticResource CardFrame}">

                        <Grid ColumnDefinitions="Auto,*,Auto">

                            <Label
                                Text="🚪"
                                FontSize="22"
                                VerticalOptions="Center"/>

                            <Label
                                Grid.Column="1"
                                Text="Logout"
                                Margin="15,0"
                                Style="{StaticResource NormalLabel}"
                                VerticalOptions="Center"/>

                            <Label
                                Grid.Column="2"
                                Text="›"
                                FontSize="28"
                                TextColor="{StaticResource SubtitleLabel}"
                                VerticalOptions="Center"/>

                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer
                                Command="{Binding LogoutCommand}" />
                            </Grid.GestureRecognizers>

                        </Grid>

                    </Frame>

                    <Frame
                        Style="{StaticResource CardFrame}">

                        <Grid ColumnDefinitions="Auto,*,Auto">

                            <Label
                                Text="🔒"
                                FontSize="22"
                                VerticalOptions="Center"/>

                            <Label
                                Grid.Column="1"
                                Text="Change Password"
                                Margin="15,0"
                                Style="{StaticResource NormalLabel}"
                                VerticalOptions="Center"/>

                            <Label
                                Grid.Column="2"
                                Text="›"
                                FontSize="28"
                                TextColor="{StaticResource SubtitleLabel}"
                                VerticalOptions="Center"/>

                            <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                            Command="{Binding ChangePasswordCommand}" />
                            </Grid.GestureRecognizers>

                        </Grid>

                      </Frame>

                </VerticalStackLayout>

        </ScrollView>
        </layouts:MainLayoutPage.PageContent>
    </layouts:MainLayoutPage>

</ContentPage>